# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Logging
LOG_LEVEL=INFO

# Data Collection
FETCH_INTERVAL=3600
MAX_WORKERS=4
REQUEST_TIMEOUT=10

# Model Training
TRAIN_INTERVAL=86400
VALIDATION_SPLIT=0.2
TEST_SPLIT=0.1

# Prediction Settings
CONFIDENCE_THRESHOLD=0.65
AGREEMENT_THRESHOLD=0.7

# Sites Configuration
BETPAWA_API_KEY=your_betpawa_api_key
BONGO_BONGO_API_KEY=your_bongo_bongo_api_key
ONEXBET_API_KEY=your_1xbet_api_key
BET365_API_KEY=your_bet365_api_key
